# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Mistral OCR API
MISTRAL_API_KEY=...

# AWS (for local development / SAM CLI)
AWS_REGION=us-east-1
S3_INPUT_BUCKET=clevercolab-input
S3_OUTPUT_BUCKET=clevercolab-output
S3_OCR_RESULTS_BUCKET=clevercolab-ocr-results
DYNAMODB_TABLE=clevercolab-jobs

# OCR provider for scanned pages: "mistral" or "textract"
OCR_PROVIDER=textract

# Local development (leave S3_OCR_RESULTS_BUCKET empty for local file output)
LOCAL_OUTPUT_DIR=output

# Application
LOG_LEVEL=INFO
JOB_TTL_HOURS=24
