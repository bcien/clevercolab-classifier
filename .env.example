# LLM provider: "anthropic", "openai", "google", or "nanonets"
LLM_PROVIDER=anthropic

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI API
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

# Google Gemini
GOOGLE_API_KEY=...
GOOGLE_MODEL=gemini-3.1-pro

# Nanonets OCR2+
NANONETS_API_KEY=...
NANONETS_API_URL=https://extraction-api.nanonets.com/extract

# Mistral OCR API
MISTRAL_API_KEY=...

# AWS (for local development / SAM CLI)
AWS_REGION=us-east-1
S3_INPUT_BUCKET=clevercolab-input
S3_OUTPUT_BUCKET=clevercolab-output
S3_OCR_RESULTS_BUCKET=clevercolab-ocr-results
DYNAMODB_TABLE=clevercolab-jobs

# OCR provider for scanned pages: "textract", "mistral", "openai", "google", or "nanonets"
OCR_PROVIDER=textract

# Local development (leave S3_OCR_RESULTS_BUCKET empty for local file output)
LOCAL_OUTPUT_DIR=output

# Application
LOG_LEVEL=INFO
JOB_TTL_HOURS=24
